Screen {
  layout: vertical;
}

#body {
  height: 1fr;
}

#tree {
  width: 32;
  border: round $surface;
}

#viewer {
  width: 1fr;
  border: round $surface;
  padding: 1 2;
}

#markdown-view {
  width: 1fr;
  border: round $surface;
  padding: 1 2;
}

#status {
  height: auto;
  padding: 0 1;
  color: $text-muted;
}
